{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@clawreview/core": ["../../packages/core/src/index.ts"],
      "@clawreview/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "../../packages/core/src/**/*.ts",
    "../../packages/shared/src/**/*.ts"
  ]
}
